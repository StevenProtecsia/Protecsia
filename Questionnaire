  btnNext.textContent = (i === LAST_FORM_STEP) ? 'Envoyer à mon conseiller' : 'Continuer';

  if(i === LAST_FORM_STEP){ buildRecap(); }
  window.scrollTo({top:0, behavior:'smooth'});
  saveDraftDebounced();
}

function isValidEmailFormat(str){
  return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(String(str).trim());
}
function isValidPhoneFormat(str){
  const digits = String(str).replace(/\D/g,'');
  return digits.length >= 9 && digits.length <= 15;
}
function highlightFieldError(field, msg){
  field.focus();
  field.style.borderColor = '#C0392B';
  setTimeout(()=>{ field.style.borderColor=''; }, 1800);
  if(msg) showToast(msg);
}

function currentStepValid(){
  const stepEl = stepEls.find(el => Number(el.dataset.step) === current);
  const required = stepEl.querySelectorAll('[required]');
  for(const f of required){
    if(!f.value || !f.value.trim()){
      highlightFieldError(f);
      return false;
    }
  }
  const emailField = stepEl.querySelector('#q_email');
  if(emailField && emailField.value.trim() && !isValidEmailFormat(emailField.value)){
    highlightFieldError(emailField, "L'adresse e-mail saisie ne semble pas valide.");
    return false;
  }
  const telField = stepEl.querySelector('#q_tel');
  if(telField && telField.value.trim() && !isValidPhoneFormat(telField.value)){
    highlightFieldError(telField, "Le numéro de téléphone saisi ne semble pas valide.");
    return false;
  }
  const cpField = stepEl.querySelector('#q_code_postal');
  if(cpField && cpField.value.trim() && !/^\d{5}$/.test(cpField.value.trim())){
    highlightFieldError(cpField, "Le code postal doit comporter 5 chiffres.");
    return false;
  }
  if(current === LAST_FORM_STEP){
    if(!document.getElementById('q_consent').checked){
      showToast("Merci de cocher la case de consentement.");
      return false;
    }
  }
  return true;
}

async function goNext(){
  if(!currentStepValid()) return;
  if(current === LAST_FORM_STEP){
    await submitForm();
    return;
  }
  if(current < LAST_FORM_STEP){
    current++;
    showStep(current);
  }
}
function goPrev(){
  if(current > 0){
    current--;
    showStep(current);
  }
}

