function buildRecap(){
  const d = normalizeForDisplay(gatherData());
  const groups = getRecapGroups(d);

  let html = '';
  groups.forEach(([title, lines])=>{
    const filled = lines.filter(([,v])=>v);
    if(filled.length === 0) return;
    html += `<div class="recap-group"><h4>${title}</h4>`;
    filled.forEach(([k,v])=>{
      html += `<div class="recap-line"><span>${k}</span><span>${escapeHtml(v)}</span></div>`;
    });
    html += `</div>`;
  });
  document.getElementById('recapZone').innerHTML = html || '<p class="recap-empty">Aucune information saisie.</p>';
}

function escapeHtml(s){
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

