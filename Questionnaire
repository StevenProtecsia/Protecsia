<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
<title>Bilan Mutuelle, Prévoyance & Retraite TNS — Protecsia</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
  :root{
    --brand:#225378;
    --brand-dark:#16324A;
    --brand-mid:#2E6690;
    --brand-light:#7FA7C2;
    --brand-pale:#E4ECF1;
    --cream:#F6F8FA;
    --paper:#FFFFFF;
    --ink:#1F2733;
    --ink-soft:#5C6B7A;
    --line:#DCE3EA;
    --good:#3F7D58;
    --radius:14px;
    --maxw:680px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--cream);
    color:var(--ink);
    font-family:'Inter',system-ui,sans-serif;
    -webkit-font-smoothing:antialiased;
    min-height:100vh;
    padding-bottom:24px;
  }
  h1,h2,h3{font-family:'Fraunces',serif;font-weight:600;color:var(--brand-dark);margin:0;}
  a{color:var(--brand-mid);}

  .topbar{background:var(--brand-dark); color:#fff; padding:18px 20px 14px; position:relative; overflow:hidden;}
  .topbar::after{content:""; position:absolute; left:0; right:0; bottom:0; height:3px; background:linear-gradient(90deg, var(--brand-mid), var(--brand-light), var(--brand-mid));}
  .topbar-inner{max-width:var(--maxw); margin:0 auto; display:flex; align-items:center; justify-content:space-between; gap:12px;}
  .brand{display:flex; align-items:center; gap:10px;}
  .brand-mark{width:38px;height:38px;border-radius:9px; background:#fff; border:1px solid rgba(255,255,255,.5); padding:4px; object-fit:contain; flex-shrink:0;}
  .brand-text{line-height:1.1;}
  .brand-text strong{display:block;font-size:15px;letter-spacing:.02em;}
  .brand-text span{display:block;font-size:11px;color:var(--brand-light);letter-spacing:.04em;}
  .duration-chip{font-size:11.5px; color:var(--brand-dark); background:var(--brand-pale); padding:5px 10px; border-radius:20px; white-space:nowrap; font-weight:600;}

  .progress-wrap{max-width:var(--maxw); margin:14px auto 0; padding:0 20px;}
  .progress-track{height:5px; background:rgba(255,255,255,.18); border-radius:6px; overflow:hidden;}
  .progress-fill{height:100%; width:0%; background:linear-gradient(90deg,var(--brand-mid),var(--brand-light)); transition:width .35s ease;}
  .progress-label{display:flex; justify-content:space-between; margin-top:6px; font-size:11.5px; color:rgba(255,255,255,.75);}

  main{max-width:var(--maxw); margin:0 auto; padding:22px 18px 0;}
  .card{background:var(--paper); border:1px solid var(--line); border-radius:18px; padding:26px 24px 22px; box-shadow:0 1px 2px rgba(22,50,74,.05);}
  .step{display:none; animation:fadein .3s ease;}
  .step.active{display:block;}
  @keyframes fadein{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}

  .step-eyebrow{display:inline-flex; align-items:center; gap:6px; font-size:11.5px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--brand-mid); margin-bottom:8px;}
  .step-eyebrow .dot{width:6px;height:6px;border-radius:50%;background:var(--brand-mid);}
  .step h2{font-size:21px; margin-bottom:6px;}
  .step-intro{color:var(--ink-soft); font-size:14px; line-height:1.55; margin-bottom:22px;}

  .legal-box{background:var(--cream); border:1px solid var(--line); border-radius:10px; padding:14px 15px; font-size:12px; line-height:1.6; color:var(--ink-soft); margin-bottom:20px;}
  .legal-box strong{color:var(--brand-dark);}


  .field{margin-bottom:18px;}
  .field-row{display:flex; gap:14px;}
  .field-row .field{flex:1; min-width:0;}
  label.flabel{display:block; font-size:13.5px; font-weight:600; color:var(--brand-dark); margin-bottom:6px;}
  label.flabel .opt{color:var(--ink-soft); font-weight:400; font-size:12px;}
  input[type=text], input[type=email], input[type=tel], input[type=number], input[type=date], select, textarea{
    width:100%; padding:11px 13px; border:1.5px solid var(--line); border-radius:10px;
    font-family:'Inter',sans-serif; font-size:14.5px; color:var(--ink); background:var(--paper); transition:border-color .15s;
  }
  textarea{resize:vertical; min-height:70px;}
  input:focus, select:focus, textarea:focus{outline:none; border-color:var(--brand-mid); box-shadow:0 0 0 3px rgba(34,83,120,.10);}
  select{
    appearance:none; -webkit-appearance:none;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8'><path d='M1 1l5 5 5-5' stroke='%235C6B7A' stroke-width='1.6' fill='none' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat:no-repeat; background-position:right 13px center; padding-right:34px; cursor:pointer;
  }
  .sub-label{font-size:11.5px; color:var(--ink-soft); margin:0 0 8px; text-transform:uppercase; letter-spacing:.04em; font-weight:700;}

  .why{margin-top:6px;}
  .why summary{list-style:none; cursor:pointer; font-size:12px; color:var(--brand-mid); font-weight:600; display:inline-flex; align-items:center; gap:5px; user-select:none;}
  .why summary::-webkit-details-marker{display:none;}
  .why summary .ico{width:15px;height:15px;border-radius:50%;border:1.4px solid var(--brand-mid); display:inline-flex;align-items:center;justify-content:center;font-size:10px;font-style:italic; font-family:Georgia,serif;}
  .why p{margin:7px 0 0; padding:10px 12px; background:var(--cream); border-left:3px solid var(--brand-mid); border-radius:0 8px 8px 0; font-size:12.5px; color:var(--ink-soft); line-height:1.5;}

  .tiles{display:grid; grid-template-columns:1fr 1fr; gap:10px;}
  @media (max-width:420px){.tiles{grid-template-columns:1fr;}}
  .tile{border:1.5px solid var(--line); border-radius:11px; padding:12px 13px; display:flex; align-items:flex-start; gap:9px; cursor:pointer; transition:.15s; background:var(--paper);}
  .tile:hover{border-color:var(--brand-light);}
  .tile input{margin-top:2px; accent-color:var(--brand-mid); width:16px; height:16px; flex-shrink:0;}
  .tile span{font-size:13.5px; line-height:1.35; color:var(--ink);}
  .tile.checked{border-color:var(--brand-mid); background:var(--brand-pale);}

  .radio-row{display:flex; flex-wrap:wrap; gap:8px;}
  .radio-pill{border:1.5px solid var(--line); border-radius:30px; padding:9px 16px; font-size:13px; cursor:pointer; color:var(--ink); transition:.15s; background:var(--paper);}
  .radio-pill input{display:none;}
  .radio-pill.checked{background:var(--brand-dark); color:#fff; border-color:var(--brand-dark);}

  .conditional{margin-top:10px; display:none;}
  .conditional.show{display:block;}

  .divider{height:1px; background:var(--line); margin:22px 0;}

  .pillar-box{border:1.5px solid var(--line); border-radius:14px; padding:16px; margin-bottom:4px;}
  .pillar-head{margin-bottom:4px;}
  .pillar-head .ttl{font-family:'Fraunces',serif; font-weight:600; color:var(--brand-dark); font-size:16px;}

  .kcard{border:1.5px solid var(--line); border-radius:12px; padding:14px; margin-bottom:12px;}
  .kcard h4{font-size:13.5px; margin:0 0 10px; color:var(--brand-dark); font-family:'Inter',sans-serif; font-weight:700;}

  .navbar{background:var(--paper); border:1px solid var(--line); border-radius:var(--radius); padding:16px 18px; margin-top:16px;}
  .navbar-inner{max-width:var(--maxw); margin:0 auto; display:flex; gap:10px; align-items:center;}
  .btn{flex:1; padding:13px 18px; border-radius:10px; border:none; font-size:14.5px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; transition:.15s;}
  .btn-primary{background:var(--brand-dark); color:#fff;}
  .btn-primary:hover{background:var(--brand);}
  .btn-ghost{background:transparent; color:var(--brand-mid); border:1.5px solid var(--line); flex:0 0 auto; padding:13px 16px;}
  .btn-ghost:hover{border-color:var(--brand-mid);}
  .btn:disabled{opacity:.4; cursor:not-allowed;}

  .recap-group{margin-bottom:16px;}
  .recap-group h4{font-size:12px; text-transform:uppercase; letter-spacing:.05em; color:var(--brand-mid); margin:0 0 8px; font-family:'Inter',sans-serif; font-weight:700;}
  .recap-line{display:flex; justify-content:space-between; gap:14px; padding:7px 0; border-bottom:1px dashed var(--line); font-size:13.5px;}
  .recap-line span:first-child{color:var(--ink-soft);}
  .recap-line span:last-child{font-weight:600; text-align:right;}
  .recap-empty{color:var(--ink-soft); font-style:italic; font-size:13px;}

  .consent{display:flex; gap:10px; align-items:flex-start; background:var(--cream); border-radius:10px; padding:14px; font-size:12.5px; color:var(--ink-soft); line-height:1.5;}
  .consent input{margin-top:3px; width:16px; height:16px; flex-shrink:0; accent-color:var(--brand-mid);}
  .attestation{font-size:12.5px; color:var(--ink-soft); line-height:1.6; margin-bottom:16px;}

  .doc-item{display:flex; align-items:center; gap:10px; border:1.5px solid var(--line); border-radius:10px; padding:10px 12px; margin-bottom:8px; background:var(--paper);}
  .doc-item .doc-ico{width:32px; height:32px; border-radius:8px; background:var(--brand-pale); color:var(--brand-dark); display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0;}
  .doc-item .doc-info{flex:1; min-width:0;}
  .doc-item .doc-name{font-size:13px; font-weight:600; color:var(--ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .doc-item .doc-size{font-size:11px; color:var(--ink-soft);}
  .doc-item .doc-remove{flex-shrink:0; width:28px; height:28px; border-radius:50%; border:none; background:var(--cream); color:#C0392B; font-size:15px; cursor:pointer; display:flex; align-items:center; justify-content:center;}
  .doc-item .doc-remove:hover{background:#FBE4E1;}

  .fallback-box{margin-top:16px; display:none;}
  .fallback-box.show{display:block;}
  .fallback-box textarea{font-size:12px; font-family:ui-monospace,monospace;}

  .hero-icon{width:52px;height:52px;border-radius:14px; background:linear-gradient(155deg,var(--brand),var(--brand-dark)); display:flex;align-items:center;justify-content:center; margin-bottom:16px;}
  .hero-icon svg{width:26px;height:26px;}
  .points{margin:18px 0 0; padding:0; list-style:none;}
  .points li{display:flex; gap:10px; font-size:13.5px; color:var(--ink); margin-bottom:10px; align-items:flex-start;}
  .points li .num{flex-shrink:0; width:20px;height:20px;border-radius:50%; background:var(--cream); border:1px solid var(--brand-light); color:var(--brand-dark); font-size:11px; font-weight:700; display:flex;align-items:center;justify-content:center;}
  .success-wrap{text-align:center; padding:18px 0;}
  .success-wrap .check{width:60px;height:60px;border-radius:50%; background:var(--good); margin:0 auto 16px; display:flex;align-items:center;justify-content:center;}
  .footnote{text-align:center; font-size:11.5px; color:var(--ink-soft); margin-top:18px;}
  .toast{position:fixed; top:14px; left:50%; transform:translateX(-50%); background:var(--brand-dark); color:#fff; padding:10px 18px; border-radius:30px; font-size:12.5px; z-index:50; box-shadow:0 4px 14px rgba(0,0,0,.18); opacity:0; transition:opacity .25s; pointer-events:none;}
  .toast.show{opacity:1;}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <div class="brand">
      <img class="brand-mark" src="data:image/png;base64," alt="Protecsia">
      <div class="brand-text">
        <strong>Protecsia</strong>
        <span>Conseil en gestion de patrimoine</span>
      </div>
    </div>
    <div class="duration-chip">⏱ 8–10 min</div>
  </div>
  <div class="progress-wrap">
    <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
    <div class="progress-label">
      <span id="progressStepLabel">Étape 1 / 11</span>
      <span id="progressNameLabel"></span>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<main>
  <div class="card">

    <div style="position:absolute; left:-9999px; width:1px; height:1px; overflow:hidden;" aria-hidden="true">
      <label for="q_hp_website">Site web (laisser vide)</label>
      <input type="text" id="q_hp_website" name="q_hp_website" tabindex="-1" autocomplete="off">
    </div>

    <!-- STEP 0 : INTRO -->
    <section class="step active" data-step="0">
      <div class="hero-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#E4ECF1" stroke-width="1.6"><path d="M12 21s-7-4.35-9-9C1.5 7.5 4 4 7.5 4c2 0 3.5 1.2 4.5 2.7C13 5.2 14.5 4 16.5 4 20 4 22.5 7.5 21 12c-2 4.65-9 9-9 9z"/></svg>
      </div>
      <span class="step-eyebrow"><span class="dot"></span> Questionnaire TNS</span>
      <h2>Faisons connaissance, simplement</h2>
      <p class="step-intro">
        En tant qu'indépendant, votre protection sociale et fiscale ne ressemble pas à celle d'un salarié. Ce questionnaire nous permet de dresser un état des lieux précis de votre situation, pour construire ensemble la stratégie la plus adaptée.
      </p>
      <div class="legal-box">
        <strong>Important.</strong> Ce questionnaire porte uniquement sur votre situation et vos garanties actuelles — aucune question médicale n'est posée ici. Si une souscription ou une modification de contrat de prévoyance est envisagée par la suite, un questionnaire de santé spécifique vous sera transmis séparément par l'assureur, comme l'exige la réglementation.
      </div>
      <ul class="points">
        <li><span class="num">1</span> Vous pouvez avancer et revenir en arrière librement.</li>
        <li><span class="num">2</span> Aucune réponse n'est jugée.</li>
        <li><span class="num">3</span> En fin de parcours, vous m'envoyez le récapitulatif en un clic.</li>
      </ul>
      <div class="field" style="margin-top:24px;">
        <label class="flabel">Votre nom et prénom</label>
        <input type="text" id="q_nom" placeholder="ex : Marie Dupont" required>
      </div>
      <div id="draftNotice" style="display:none; margin-top:14px; background:var(--cream); border:1px solid var(--line); border-radius:10px; padding:12px 14px; font-size:12.5px; color:var(--ink-soft); align-items:center; justify-content:space-between; gap:10px;">
        <span>Une saisie précédente non terminée a été restaurée.</span>
        <button type="button" class="btn btn-ghost" style="flex:0 0 auto; padding:6px 12px; font-size:11.5px;" onclick="clearDraftAndReload()">Effacer et recommencer</button>
      </div>
    </section>

    <!-- STEP 1 : IDENTITE -->
    <section class="step" data-step="1">
      <span class="step-eyebrow"><span class="dot"></span> 1 · Identité</span>
      <h2>Vos coordonnées</h2>
      <p class="step-intro">De quoi vous recontacter et préparer votre dossier.</p>

      <div class="field">
        <label class="flabel">Civilité</label>
        <div class="radio-row" data-group="q_civilite">
          <label class="radio-pill"><input type="radio" name="q_civilite" value="Madame"> Madame</label>
          <label class="radio-pill"><input type="radio" name="q_civilite" value="Monsieur"> Monsieur</label>
        </div>
      </div>

      <div class="field-row">
        <div class="field">
          <label class="flabel">Date de naissance</label>
          <input type="date" id="q_dob" required>
        </div>
        <div class="field">
          <label class="flabel">Lieu de naissance</label>
          <input type="text" id="q_lieu_naissance" placeholder="ex : Paris">
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label class="flabel">Nationalité</label>
          <input type="text" id="q_nationalite" placeholder="ex : Française" value="Française">
        </div>
        <div class="field">
          <label class="flabel">Téléphone</label>
          <input type="tel" id="q_tel" placeholder="06 12 34 56 78" required>
        </div>
      </div>
      <div class="field">
        <label class="flabel">E-mail</label>
        <input type="email" id="q_email" placeholder="vous@exemple.fr" required>
      </div>
      <div class="field">
        <label class="flabel">Adresse</label>
        <input type="text" id="q_adresse" placeholder="N° et nom de rue">
      </div>
      <div class="field-row">
        <div class="field">
          <label class="flabel">Code postal</label>
          <input type="text" id="q_code_postal" placeholder="ex : 92200" inputmode="numeric" maxlength="5">
        </div>
        <div class="field">
          <label class="flabel">Ville</label>
          <select id="q_ville">
            <option value="">Saisissez d'abord le code postal…</option>
          </select>
        </div>
      </div>

      <div class="divider"></div>

      <div class="field">
        <label class="flabel">Êtes-vous une Personne Politiquement Exposée (PPE) ?</label>
        <div class="radio-row" data-group="q_ppe">
          <label class="radio-pill"><input type="radio" name="q_ppe" value="Non"> Non</label>
          <label class="radio-pill"><input type="radio" name="q_ppe" value="Oui"> Oui</label>
        </div>
        <div class="conditional" id="ppeDetailWrap">
          <input type="text" id="q_ppe_detail" placeholder="Précisez la fonction concernée">
        </div>
      </div>
      <div class="field">
        <label class="flabel">Êtes-vous une "US Person" au sens FATCA ?</label>
        <div class="radio-row" data-group="q_fatca">
          <label class="radio-pill"><input type="radio" name="q_fatca" value="Non"> Non</label>
          <label class="radio-pill"><input type="radio" name="q_fatca" value="Oui"> Oui</label>
        </div>
        <div class="conditional" id="fatcaDetailWrap">
          <input type="text" id="q_fatca_detail" placeholder="Précisez">
        </div>
      </div>
    </section>

    <!-- STEP 2 : ACTIVITE TNS -->
    <section class="step" data-step="2">
      <span class="step-eyebrow"><span class="dot"></span> 2 · Votre activité</span>
      <h2>Votre statut d'indépendant</h2>
      <p class="step-intro">Votre statut juridique et social détermine directement vos droits actuels et les plafonds disponibles pour optimiser votre couverture.</p>

      <div class="field">
        <label class="flabel">Statut juridique</label>
        <select id="q_statut_juridique" required>
          <option value="">Sélectionner…</option>
          <option>Entreprise individuelle (EI)</option>
          <option>EURL à l'IR (gérant unique)</option>
          <option>EURL / SARL à l'IS (gérant majoritaire)</option>
          <option>SELARL (gérant majoritaire)</option>
          <option>SELAS / SELASU</option>
          <option>SASU / SAS (assimilé salarié)</option>
          <option>Profession libérale réglementée</option>
          <option>Profession libérale non réglementée</option>
          <option>Artisan</option>
          <option>Commerçant</option>
          <option>Exploitant agricole</option>
        </select>
        <details class="why"><summary><span class="ico">i</span> Pourquoi cette question ?</summary>
          <p>Un gérant majoritaire, une profession libérale et un assimilé salarié n'ont pas le même régime social ni les mêmes plafonds de cotisation pour la prévoyance et la retraite.</p>
        </details>
      </div>

      <div class="field">
        <label class="flabel">Régime social</label>
        <select id="q_regime_social">
          <option value="">Sélectionner…</option>
          <option>Régime des indépendants (SSI)</option>
          <option>CIPAV (profession libérale réglementée)</option>
          <option>Régime général (assimilé salarié)</option>
          <option>Autre / je ne sais pas</option>
        </select>
      </div>

      <div class="field">
        <label class="flabel">Secteur d'activité</label>
        <select id="q_secteur">
          <option value="">Sélectionner…</option>
          <option>Santé / Médical</option>
          <option>Juridique / Droit</option>
          <option>Finance / Banque / Assurance</option>
          <option>Immobilier</option>
          <option>BTP / Construction</option>
          <option>Industrie</option>
          <option>Artisanat</option>
          <option>Commerce / Distribution</option>
          <option>Restauration / Hôtellerie / Tourisme</option>
          <option>Transport / Logistique</option>
          <option>Tech / Informatique</option>
          <option>Conseil / Services aux entreprises</option>
          <option>Enseignement / Formation</option>
          <option>Culture / Communication / Média</option>
          <option>Agriculture</option>
          <option>Autre</option>
        </select>
        <div class="conditional" id="secteurAutreWrap">
          <input type="text" id="q_secteur_autre" placeholder="Précisez votre secteur / métier">
        </div>
      </div>

      <div class="field">
        <label class="flabel">Votre profession exacte <span class="opt">(facultatif)</span></label>
        <input type="text" id="q_profession" placeholder="ex : chirurgien-dentiste, architecte d'intérieur, consultant SI…">
      </div>

      <div class="field-row">
        <div class="field">
          <label class="flabel">Ancienneté de l'activité</label>
          <select id="q_anciennete">
            <option value="">Sélectionner…</option>
            <option>Moins d'1 an</option>
            <option>1 à 3 ans</option>
            <option>3 à 5 ans</option>
            <option>5 à 10 ans</option>
            <option>Plus de 10 ans</option>
          </select>
        </div>
        <div class="field">
          <label class="flabel">Régime fiscal</label>
          <select id="q_regime_fiscal">
            <option value="">Sélectionner…</option>
            <option>Micro-BIC</option>
            <option>BIC réel</option>
            <option>Micro-BNC</option>
            <option>BNC réel (déclaration contrôlée)</option>
            <option>Impôt sur les sociétés (IS)</option>
          </select>
        </div>
      </div>

      <div class="conditional field-row" id="isDetailWrap">
        <div class="field">
          <label class="flabel">Rémunération annuelle nette (dirigeant)</label>
