  document.getElementById('fallbackBox').classList.remove('show');
  document.getElementById('sendingBox').classList.add('show');
  btnNext.disabled = true; btnPrev.disabled = true;
  const originalLabel = btnNext.textContent;
  btnNext.textContent = 'Envoi en cours…';

