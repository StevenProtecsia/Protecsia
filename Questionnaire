function showStep(i){
  stepEls.forEach(el => el.classList.toggle('active', Number(el.dataset.step) === i));
  const pct = Math.round((i / LAST_FORM_STEP) * 100);
  document.getElementById('progressFill').style.width = Math.min(pct,100) + '%';
  if(i <= LAST_FORM_STEP){
    document.getElementById('progressStepLabel').textContent = `Étape ${i+1} / ${LAST_FORM_STEP+1}`;
  }
