function normalizeForDisplay(d){
  const nameFields = ['nom','lieu_naissance','nationalite','adresse','ville','secteur','profession',
                       'ppe_detail','fatca_detail','mutuelle_assureur','prevoyance_assureur','per_assureur'];
  const sentenceFields = ['charge_detail','commentaire','mutuelle_echeance'];
  const moneyFields = ['remuneration_dirigeant','dividendes','revenu_pro_mensuel','revenu_pro_annuel',
                        'mutuelle_cotisation','prevoyance_it_montant','prevoyance_deces_capital','emprunteur_cotisation',
                        'per_cotisation_mensuelle','per_versement_annuel','per_encours','per_plafond_montant','revenu_complementaire'];
  const out = Object.assign({}, d);
  nameFields.forEach(k=>{ if(out[k]) out[k] = toTitleCase(out[k]); });
  sentenceFields.forEach(k=>{ if(out[k]) out[k] = capitalizeSentence(out[k]); });
  moneyFields.forEach(k=>{ if(out[k]) out[k] = formatMoney(out[k]); });
  out.email = formatEmailDisplay(out.email);
  out.tel = formatPhoneDisplay(out.tel);
  return out;
}

