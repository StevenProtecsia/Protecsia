const PROTECSIA_LOGO_DATAURL = (function(){
  const img = document.querySelector('.brand-mark');
  return img ? img.getAttribute('src') : null;
})();

function generatePdf(d){
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ unit:'pt', format:'a4' });
  const pageW = doc.internal.pageSize.getWidth();
  const pageH = doc.internal.pageSize.getHeight();
  const marginX = 48;
  const lineHeight = 14;
  const headerH = 78;
  const footerH = 34;
  const contentW = pageW - marginX*2;

  const C_BRAND_DARK = [22,50,74];
  const C_BRAND_MID  = [46,102,144];
  const C_BRAND_LIGHT= [127,167,194];
  const C_BRAND_PALE = [228,236,241];
  const C_INK        = [31,39,51];
  const C_INK_SOFT   = [92,107,122];
  const C_ZEBRA      = [244,247,250];
  const C_GOOD_BG    = [231,244,236];
  const C_GOOD_TEXT  = [47,110,77];

  let y = 0;

  function drawHeader(){
    doc.setFillColor(...C_BRAND_DARK);
    doc.rect(0,0,pageW,headerH,'F');
    doc.setFillColor(...C_BRAND_LIGHT);
    doc.rect(0,headerH-3,pageW,3,'F');

    let textX = marginX;
    if(PROTECSIA_LOGO_DATAURL){
      try{ doc.addImage(PROTECSIA_LOGO_DATAURL, 'PNG', marginX, 16, 32, 32); textX = marginX + 44; }catch(e){}
    }
    doc.setTextColor(255,255,255);
    doc.setFont('helvetica','bold');
    doc.setFontSize(15);
    doc.text('PROTECSIA', textX, 33);
    doc.setFont('helvetica','normal');
    doc.setFontSize(9.5);
    doc.text('Questionnaire TNS — Mutuelle, prévoyance & retraite', textX, 48);
    doc.setFontSize(8.5);
    doc.setTextColor(190,205,220);
    doc.text(`Reçu le ${new Date().toLocaleString('fr-FR')}`, textX, 61);

    doc.setFont('helvetica','bold');
    doc.setFontSize(11);
    doc.setTextColor(255,255,255);
    doc.text(d.nom || 'Client', pageW - marginX, 33, { align:'right' });
    doc.setFont('helvetica','normal');
    doc.setFontSize(8.5);
    doc.setTextColor(190,205,220);
    if(d.email) doc.text(d.email, pageW - marginX, 47, { align:'right' });

    y = headerH + 30;
  }

  function drawFooter(){
    const n = doc.internal.getNumberOfPages();
    for(let i = 1; i <= n; i++){
      doc.setPage(i);
      doc.setDrawColor(220,227,234);
      doc.line(marginX, pageH - footerH, pageW - marginX, pageH - footerH);
      let fx = marginX;
      if(PROTECSIA_LOGO_DATAURL){
        try{ doc.addImage(PROTECSIA_LOGO_DATAURL, 'PNG', marginX, pageH - footerH + 8, 11, 11); fx = marginX + 16; }catch(e){}
      }
      doc.setFont('helvetica','normal');
      doc.setFontSize(7.5);
      doc.setTextColor(...C_INK_SOFT);
      doc.text('SAS Protecsia — 20 rue d\'Armenonville, 92200 Neuilly-sur-Seine — ORIAS 24002899 / RCS 983 958 158', fx, pageH - footerH + 14);
      doc.text('Document confidentiel — usage exclusif Protecsia', fx, pageH - footerH + 25);
      doc.text(`Page ${i} / ${n}`, pageW - marginX, pageH - footerH + 14, { align:'right' });
    }
  }

  function ensureSpace(needed){
    if(y + needed > pageH - footerH - 14){
      doc.addPage();
      drawHeader();
    }
  }

  function drawSectionTitle(title){
    ensureSpace(36);
    doc.setFillColor(...C_BRAND_MID);
    doc.roundedRect(marginX, y - 9, 7, 7, 1.5, 1.5, 'F');
    doc.setFont('helvetica','bold');
    doc.setFontSize(11);
    doc.setTextColor(...C_BRAND_DARK);
    doc.text(title.toUpperCase(), marginX + 13, y);
    y += 8;
    doc.setDrawColor(...C_BRAND_LIGHT);
    doc.setLineWidth(0.7);
    doc.line(marginX, y, pageW - marginX, y);
    doc.setLineWidth(1);
    y += 16;
  }

  let __rowToggle = 0;
  function drawKV(label, value){
    const labelText = label + ' : ';
    doc.setFont('helvetica','bold');
    doc.setFontSize(9.5);
    const labelWidth = doc.getTextWidth(labelText);
    doc.setFont('helvetica','normal');
    const wrapped = doc.splitTextToSize(String(value), Math.max(contentW - labelWidth, 80));
    const rowH = wrapped.length * lineHeight;
    ensureSpace(rowH + 4);
    __rowToggle++;
    if(__rowToggle % 2 === 0){
      doc.setFillColor(...C_ZEBRA);
      doc.rect(marginX - 6, y - 9, contentW + 12, rowH, 'F');
    }
    doc.setFont('helvetica','bold');
    doc.setFontSize(9.5);
    doc.setTextColor(...C_BRAND_MID);
    doc.text(labelText, marginX, y);
    doc.setFont('helvetica','normal');
    doc.setTextColor(...C_INK);
    wrapped.forEach((line,idx)=>{
      doc.text(line, marginX + labelWidth, y + idx*lineHeight);
    });
    y += rowH + 2;
  }

  function drawChipsRow(items){
    const chipH = 16, padX = 7, gapX = 6, rowGap = 6;
    doc.setFont('helvetica','normal');
    doc.setFontSize(8.5);
    let x = marginX;
    ensureSpace(chipH);
    items.forEach(item=>{
      const w = doc.getTextWidth(item) + padX*2;
      if(x + w > pageW - marginX){
        x = marginX;
        y += chipH + rowGap;
        ensureSpace(chipH);
      }
      doc.setFillColor(...C_BRAND_PALE);
      doc.roundedRect(x, y, w, chipH, chipH/2, chipH/2, 'F');
      doc.setTextColor(...C_BRAND_DARK);
      doc.text(item, x + padX, y + chipH/2 + 3);
      x += w + gapX;
    });
    y += chipH + 6;
  }

  function drawChipsField(label, items){
    const vals = (items || []).filter(Boolean);
    if(vals.length === 0) return;
    ensureSpace(30);
    doc.setFont('helvetica','bold');
    doc.setFontSize(9);
    doc.setTextColor(...C_BRAND_MID);
    doc.text(label.toUpperCase(), marginX, y);
    y += 12;
    drawChipsRow(vals);
  }

  drawHeader();

  const CHIP_LINE_LABELS = {
    'Priorités sélectionnées': 'objectifs'
  };

  const groups = getRecapGroups(d);
  groups.forEach(([title, lines])=>{
    const filled = lines.filter(([,v])=>v);
    if(filled.length === 0) return;

    drawSectionTitle(title);
    __rowToggle = 0;
    filled.forEach(([k,v])=>{
      if(CHIP_LINE_LABELS[k]){
        drawChipsField(k, d[CHIP_LINE_LABELS[k]]);
      }else{
        drawKV(k, v);
      }
    });

    if(title === 'Retraite & PER' && (d.autres_dispositifs||[]).filter(Boolean).length > 0){
      drawChipsField('Autres dispositifs retraite', d.autres_dispositifs);
    }

    y += 10;
  });

  ensureSpace(90);
  y += 6;
  const attestation = "Le client reconnaît que les informations contenues dans ce document sont sincères et exactes, et s'engage à informer son conseiller de toute modification de sa situation.";
  doc.setFont('helvetica','italic');
  doc.setFontSize(8.5);
  const attLines = doc.splitTextToSize(attestation, contentW - 30);
  const boxH = attLines.length * 12 + 18;
  ensureSpace(boxH + 10);
  doc.setFillColor(...C_BRAND_PALE);
  doc.setDrawColor(...C_BRAND_LIGHT);
  doc.setLineWidth(0.8);
  doc.roundedRect(marginX, y, contentW, boxH, 5, 5, 'FD');
  doc.setLineWidth(1);
  doc.setTextColor(...C_BRAND_DARK);
  doc.setDrawColor(...C_BRAND_MID);
  doc.setLineWidth(0.8);
  doc.circle(marginX + 13, y + 14, 6, 'S');
  doc.setLineWidth(1);
  doc.setFont('helvetica','bolditalic');
  doc.setFontSize(8.5);
  doc.text('i', marginX + 11.3, y + 17);
  doc.setFont('helvetica','italic');
  doc.setFontSize(8.5);
  doc.setTextColor(...C_INK_SOFT);
  let attY = y + 18;
  attLines.forEach(line=>{
    doc.text(line, marginX + 24, attY);
    attY += 12;
  });
  y += boxH + 16;

  const stampText = `Document validé électroniquement par ${d.nom || 'le client'} le ${new Date().toLocaleDateString('fr-FR')}`;
  doc.setFont('helvetica','bold');
  doc.setFontSize(9);
  const stampIconZone = 26;
  const stampW = Math.min(doc.getTextWidth(stampText) + stampIconZone + 22, contentW);
  const stampH = 22;
  ensureSpace(stampH + 6);
  doc.setFillColor(...C_GOOD_BG);
  doc.roundedRect(marginX, y, stampW, stampH, stampH/2, stampH/2, 'F');

  const checkCx = marginX + 16, checkCy = y + stampH/2;
  doc.setFillColor(...C_GOOD_TEXT);
  doc.circle(checkCx, checkCy, 7, 'F');
  doc.setDrawColor(255,255,255);
  doc.setLineWidth(1.4);
  doc.line(checkCx - 3.2, checkCy + 0.3, checkCx - 0.8, checkCy + 3);
  doc.line(checkCx - 0.8, checkCy + 3, checkCx + 3.6, checkCy - 3.2);
  doc.setLineWidth(1);

  doc.setTextColor(...C_GOOD_TEXT);
  doc.text(stampText, marginX + stampIconZone, y + stampH/2 + 3);
  y += stampH;

  drawFooter();

  const safeName = (d.nom || 'client').replace(/[^a-zA-Z0-9-]+/g,'-');
  const filename = `Questionnaire-TNS-${safeName}.pdf`;
  return { blob: doc.output('blob'), filename };
}

