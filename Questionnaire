    const pdf = generatePdf(d);
    pdfBlob = pdf.blob; filename = pdf.filename;
  }catch(e){ console.error('Génération PDF impossible :', e); }

  window.__lastPdfBlob = pdfBlob;
  window.__lastPdfFilename = filename;

  let success = false;
  if(pdfBlob){
    try{
      const fd = new FormData();
      fd.append('nom', d.nom || 'Client');
      fd.append('email', d.email || '');
      fd.append('sujet', `Questionnaire TNS — Mutuelle, prévoyance & retraite — ${d.nom || 'Client'}`);
      fd.append('message', buildEmailBody(d));
      fd.append('pdf', pdfBlob, filename);
      fd.append('hp', (document.getElementById('q_hp_website') || {}).value || '');
      fd.append('elapsed_ms', String(Date.now() - __pageLoadedAt));
      attachedDocuments.forEach(doc => { fd.append('documents[]', doc.file, doc.file.name); });
      const res = await fetch(SEND_ENDPOINT, { method:'POST', body: fd });
      const json = await res.json().catch(()=>({success:false}));
      success = res.ok && json.success;
    }catch(e){ console.error('Envoi vers le serveur échoué :', e); }
  }

  document.getElementById('sendingBox').classList.remove('show');
  btnNext.disabled = false; btnPrev.disabled = false;
  btnNext.textContent = originalLabel;

  if(success){
    clearDraft();
    current = SUCCESS_STEP;
    showStep(current);
  }else{
    const subject = encodeURIComponent(`Questionnaire TNS — ${d.nom || 'Client'}`);
    const bodyTxt = encodeURIComponent("Bonjour, veuillez trouver ci-joint mon questionnaire TNS et mes documents (PDF téléchargé séparément, à joindre manuellement).");
    document.getElementById('fallbackMailto').href = `mailto:${ADVISOR_EMAIL}?subject=${subject}&body=${bodyTxt}`;
    document.getElementById('fallbackBox').classList.add('show');
    showToast("L'envoi automatique a échoué — téléchargez le PDF ci-dessous.");
  }
}

function downloadPdfFallback(){
  if(!window.__lastPdfBlob){
    const d = normalizeForDisplay(gatherData());
    const pdf = generatePdf(d);
    window.__lastPdfBlob = pdf.blob; window.__lastPdfFilename = pdf.filename;
  }
  const url = URL.createObjectURL(window.__lastPdfBlob);
  const a = document.createElement('a');
  a.href = url; a.download = window.__lastPdfFilename || 'questionnaire-tns.pdf';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  setTimeout(()=> URL.revokeObjectURL(url), 4000);
}

const DRAFT_STORAGE_KEY = 'protecsia_questionnaire_tns_draft_v1';
const DRAFT_MAX_AGE_MS = 1000 * 60 * 60 * 24 * 14;

function collectRawFormState(){
  const values = {};
  document.querySelectorAll('main [id]').forEach(el=>{
    const tag = el.tagName;
    if(tag === 'INPUT'){
      if(el.type === 'radio' || el.type === 'checkbox' || el.type === 'file') return;
      values[el.id] = el.value;
    } else if(tag === 'SELECT' || tag === 'TEXTAREA'){
      values[el.id] = el.value;
    }
  });
  const radios = {};
  document.querySelectorAll('main input[type=radio]').forEach(r=>{
    if(r.checked) radios[r.name] = r.value;
  });
  const tiles = {};
  document.querySelectorAll('main .tiles[id]').forEach(box=>{
    tiles[box.id] = Array.from(box.querySelectorAll('input:checked')).map(i=>i.value);
  });
  return { step: current, values, radios, tiles, savedAt: Date.now() };
}

function saveDraft(){
  try{
    localStorage.setItem(DRAFT_STORAGE_KEY, JSON.stringify(collectRawFormState()));
  }catch(e){}
}
let __saveDraftTimer = null;
function saveDraftDebounced(){
  clearTimeout(__saveDraftTimer);
  __saveDraftTimer = setTimeout(saveDraft, 400);
}
function loadDraft(){
  try{
    const raw = localStorage.getItem(DRAFT_STORAGE_KEY);
    if(!raw) return null;
    const state = JSON.parse(raw);
    if(!state || !state.savedAt || (Date.now() - state.savedAt) > DRAFT_MAX_AGE_MS) return null;
    return state;
  }catch(e){ return null; }
}
function clearDraft(){
  try{ localStorage.removeItem(DRAFT_STORAGE_KEY); }catch(e){}
}
function clearDraftAndReload(){
  clearDraft();
  window.location.reload();
}

function applyFormState(state){
  if(!state) return;

  Object.keys(state.values || {}).forEach(id=>{
    if(id === 'q_ville' || id === 'q_code_postal') return;
    const el = document.getElementById(id);
    if(!el) return;
    el.value = state.values[id];
    el.dispatchEvent(new Event('input', { bubbles:true }));
    el.dispatchEvent(new Event('change', { bubbles:true }));
  });

  Object.keys(state.radios || {}).forEach(name=>{
    const value = state.radios[name];
    const radio = Array.from(document.querySelectorAll(`input[name="${name}"]`)).find(r => r.value === value);
    if(radio){ radio.checked = true; radio.dispatchEvent(new Event('change', { bubbles:true })); }
  });

  Object.keys(state.tiles || {}).forEach(containerId=>{
    const box = document.getElementById(containerId);
    if(!box) return;
    (state.tiles[containerId] || []).forEach(value=>{
      const cb = Array.from(box.querySelectorAll('input')).find(i => i.value === value);
      if(cb){ cb.checked = true; cb.dispatchEvent(new Event('change', { bubbles:true })); }
    });
  });

  const savedCp = state.values && state.values['q_code_postal'];
  const savedVille = state.values && state.values['q_ville'];
  const cpField = document.getElementById('q_code_postal');
  if(cpField && savedCp) cpField.value = savedCp;
  if(savedCp && /^\d{5}$/.test(savedCp)){
    lookupCommunes(savedCp).then(communes=>{
      const villeSelect = document.getElementById('q_ville');
      if(!villeSelect) return;
      if(communes && communes.length){
        villeSelect.innerHTML = communes.map(c => `<option value="${c.nom}">${c.nom}</option>`).join('');
      }
      if(savedVille){
        if(!Array.from(villeSelect.options).some(o => o.value === savedVille)){
          const opt = document.createElement('option');
          opt.value = savedVille; opt.textContent = savedVille;
          villeSelect.appendChild(opt);
        }
        villeSelect.value = savedVille;
      }
    });
  }

  if(typeof state.step === 'number'){
    current = Math.min(state.step, LAST_FORM_STEP);
    showStep(current);
  }
}

document.querySelector('main').addEventListener('input', saveDraftDebounced);
document.querySelector('main').addEventListener('change', saveDraftDebounced);

const __existingDraft = loadDraft();
if(__existingDraft){
  applyFormState(__existingDraft);
  const notice = document.getElementById('draftNotice');
  if(notice) notice.style.display = 'flex';
}else{
  showStep(0);
}
</script>
