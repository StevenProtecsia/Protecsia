const MAX_DOC_SIZE = 8 * 1024 * 1024;
const MAX_TOTAL_DOCS_SIZE = 20 * 1024 * 1024;
const MAX_DOC_COUNT = 8;
let attachedDocuments = [];
let docIdCounter = 0;

function formatFileSize(bytes){
  if(bytes < 1024) return bytes + ' o';
  if(bytes < 1024*1024) return Math.round(bytes/1024) + ' Ko';
  return (bytes/(1024*1024)).toFixed(1) + ' Mo';
}
function iconForFile(name){
  return /\.(jpe?g|png)$/i.test(name) ? '🖼️' : '📄';
}
function renderDocumentsList(){
  const zone = document.getElementById('documentsListZone');
  if(attachedDocuments.length === 0){ zone.innerHTML = ''; return; }
  zone.innerHTML = attachedDocuments.map(d => `
    <div class="doc-item">
      <div class="doc-ico">${iconForFile(d.file.name)}</div>
      <div class="doc-info">
        <div class="doc-name">${escapeHtml(d.file.name)}</div>
        <div class="doc-size">${formatFileSize(d.file.size)}</div>
      </div>
      <button type="button" class="doc-remove" onclick="removeDocument(${d.id})" aria-label="Supprimer">✕</button>
    </div>
  `).join('');
}
function removeDocument(id){
  attachedDocuments = attachedDocuments.filter(d => d.id !== id);
  renderDocumentsList();
}
document.getElementById('q_documents_input').addEventListener('change', function(e){
  const files = Array.from(e.target.files || []);
  let totalSize = attachedDocuments.reduce((s,d)=> s + d.file.size, 0);
  files.forEach(file=>{
    if(attachedDocuments.length >= MAX_DOC_COUNT){
      showToast(`Maximum ${MAX_DOC_COUNT} documents.`);
      return;
    }
    if(!/\.(pdf|jpe?g|png)$/i.test(file.name)){
      showToast(`"${file.name}" : format non accepté.`);
      return;
    }
    if(file.size > MAX_DOC_SIZE){
      showToast(`"${file.name}" dépasse 8 Mo — fichier ignoré.`);
      return;
    }
    if(totalSize + file.size > MAX_TOTAL_DOCS_SIZE){
      showToast('Limite totale de 20 Mo atteinte.');
      return;
    }
    totalSize += file.size;
    attachedDocuments.push({ file, id: ++docIdCounter });
  });
  renderDocumentsList();
  e.target.value = '';
});

function parseAmount(str){
  if(!str) return 0;
  let s = String(str).trim();
  let mult = 1;
  if(/[kK]\s*$/.test(s)){ mult = 1000; s = s.replace(/[kK]\s*$/,''); }
  s = s.replace(/[^\d,.\-]/g,'');
  if(s.indexOf(',') > -1 && s.indexOf('.') === -1){ s = s.replace(',', '.'); }
  else { s = s.replace(/,/g,''); }
  const n = parseFloat(s);
  return isNaN(n) ? 0 : n * mult;
}
function formatNumberFR(n){
  const rounded = Math.round(n);
  const sign = rounded < 0 ? '-' : '';
  const digits = Math.abs(rounded).toString();
  let grouped = '';
  for(let i = 0; i < digits.length; i++){
    if(i > 0 && (digits.length - i) % 3 === 0) grouped += ' ';
    grouped += digits[i];
  }
  return sign + grouped;
}
function formatMoney(str){
  if(!str || !String(str).trim()) return '';
  const n = parseAmount(str);
  if(n === 0) return String(str).trim();
  return formatNumberFR(n) + ' €';
}

function bindMensuelAnnuelSync(mensuelId, annuelId){
  const m = document.getElementById(mensuelId);
  const a = document.getElementById(annuelId);
  let syncing = false;
  m.addEventListener('input', ()=>{
    if(syncing) return;
    const n = parseAmount(m.value);
    if(n > 0){ syncing = true; a.value = formatNumberFR(n*12); syncing = false; }
  });
  a.addEventListener('input', ()=>{
    if(syncing) return;
    const n = parseAmount(a.value);
    if(n > 0){ syncing = true; m.value = formatNumberFR(n/12); syncing = false; }
  });
}
